{
  "name": "myerscode/utilities-numbers",
  "description": "A fluent interface for interacting with numbers.",
  "keywords": [
    "numbers",
    "int",
    "float"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "myerscode",
      "email": "team@myerscode.com",
      "homepage": "https://myerscode.com"
    },
    {
      "name": "Fred Myerscough",
      "email": "fred@myerscough.co.uk",
      "homepage": "https://fredmyerscough.co.uk"
    }
  ],
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "laravel/pint": "^1.29",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Myerscode\\Utilities\\Numbers\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse",
    "tests": "vendor/bin/phpunit --testdox --no-coverage --colors=always",
    "test-coverage": "vendor/bin/phpunit --testdox --colors=always",
    "security-audit": "@composer audit"
  }
}
